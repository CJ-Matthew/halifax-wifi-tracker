# Copy this file to .env/local.env and fill in values.

SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_TABLE=devices

# Eero integration — set via the /eero/login + /eero/verify API flow, or paste manually
EERO_USER_TOKEN=
EERO_NETWORK_NAME=

# API key — protects all endpoints. Leave blank to disable auth (local dev only).
# Must match VITE_API_KEY in the frontend .env
API_KEY=

# CORS — set to your Vercel frontend URL in production (e.g. https://halifax-wifi-tracker.vercel.app)
# Leave blank to allow all origins (local dev only)
ALLOWED_ORIGIN=

# Spotify "now playing" face. CLIENT_ID/SECRET come from developer.spotify.com/dashboard.
# REFRESH_TOKEN is minted once by:  python3 -m backend.spotify_auth
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=
